{
  "manifest_version": 3,
  "name": "Fox Group Sync",
  "version": "0.1.3",
  "description": "Salva grupos de abas nativos do Firefox e sincroniza os snapshots entre Firefox desktop usando a conta Mozilla.",
  "permissions": ["storage", "tabs", "tabGroups"],
  "action": {
    "default_title": "Fox Group Sync",
    "default_popup": "popup.html"
  },
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "fox-group-sync@felipedruzian.local",
      "strict_min_version": "141.0",
      "data_collection_permissions": {
        "required": ["browsingActivity", "searchTerms"]
      }
    }
  }
}
